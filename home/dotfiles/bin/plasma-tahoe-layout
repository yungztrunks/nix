#!/usr/bin/env bash
set -euo pipefail

once_mode=false
if [[ "${1:-}" == "--once" ]]; then
  once_mode=true
fi

marker_file="$HOME/.cache/plasma-tahoe-layout.applied"
if [[ "$once_mode" == true && -f "$marker_file" ]]; then
  exit 0
fi

dbus_tool="$(command -v qdbus6 || command -v qdbus || true)"
if [[ -z "$dbus_tool" ]]; then
  echo "qdbus/qdbus6 not found; cannot apply Plasma layout." >&2
  exit 1
fi

plasma_script=$(cat <<'PLASMAJS'
var existingPanels = panels();
for (var i = existingPanels.length - 1; i >= 0; --i) {
    existingPanels[i].remove();
}

var topPanel = new Panel;
topPanel.location = "top";
topPanel.height = 36;

var topLauncher = topPanel.addWidget("org.kde.plasma.kickoff");
topLauncher.currentConfigGroup = ["Configuration", "General"];
topLauncher.writeConfig("icon", "glutmother");
topPanel.addWidget("org.kde.plasma.pager");
topPanel.addWidget("org.kde.plasma.icontasks");

var topSpacer = topPanel.addWidget("org.kde.plasma.panelspacer");
topSpacer.currentConfigGroup = ["General"];
topSpacer.writeConfig("expanding", true);

topPanel.addWidget("org.kde.plasma.systemtray");
topPanel.addWidget("org.kde.plasma.digitalclock");

var dockPanel = new Panel;
dockPanel.location = "bottom";
dockPanel.height = 52;

var dockLeftSpacer = dockPanel.addWidget("org.kde.plasma.panelspacer");
dockLeftSpacer.currentConfigGroup = ["General"];
dockLeftSpacer.writeConfig("expanding", true);

var dockLauncher = dockPanel.addWidget("org.kde.plasma.kickoff");
dockLauncher.currentConfigGroup = ["Configuration", "General"];
dockLauncher.writeConfig("alphaSort", true);
dockLauncher.writeConfig("icon", "glutmother");

var dockTasks = dockPanel.addWidget("org.kde.plasma.icontasks");
dockTasks.currentConfigGroup = ["General"];
dockTasks.writeConfig("launchers", [
    "applications:org.kde.dolphin.desktop",
    "applications:kitty.desktop",
    "applications:firefox.desktop",
    "applications:code.desktop",
    "applications:org.kde.discover.desktop"
]);

var dockRightSpacer = dockPanel.addWidget("org.kde.plasma.panelspacer");
dockRightSpacer.currentConfigGroup = ["General"];
dockRightSpacer.writeConfig("expanding", true);
PLASMAJS
)

"$dbus_tool" org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$plasma_script"

mkdir -p "$(dirname "$marker_file")"
touch "$marker_file"
